@model ProductUpdateVM;

@{
    ProductImage mainImage = Model.ProductImages.FirstOrDefault(pi => pi.IsPrimary == true);
    ProductImage hoverImage = Model.ProductImages.FirstOrDefault(pi => pi.IsPrimary == false);
    List<ProductImage> addImages = Model.ProductImages != null ? Model.ProductImages.Where(pi => pi.IsPrimary == null).ToList() : new List<ProductImage>();
}

<div class="row">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Update Product</h4>
                <form class="forms-sample" method="post" enctype="multipart/form-data">
                    <div class="form-group">
                        <div class="form-group">
                           @if (mainImage != null)
                           {
                                <img style="width:100px;" src="~/assets/images/website-images/@mainImage.Image" alt="Main Image"/>
                           }
                        </div>
                        <label for="name">MainImage</label>
                        <input asp-for="MainPhoto" class="form-control" accept="image/*">
                        <span asp-validation-for="MainPhoto" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <div class="form-group">
                            @if (hoverImage != null)
                            {
                                 <img style="width:100px;" src="~/assets/images/website-images/@hoverImage.Image" alt="Hover Image"/>
                            }
                        </div>
                        <label for="name">SecondayImage</label>
                        <input asp-for="HoverPhoto" class="form-control" accept="image/*">
                        <span asp-validation-for="HoverPhoto" class="text-danger"></span>
                    </div>
                    <div class="form-group d-flex flex-lg-wrap">
                        @foreach(ProductImage addImage in addImages)
                        {
                            <div style="position:relative">
                                <img style="width:100px;" src="~/assets/images/website-images/@addImage.Image" alt="Alternate Text"/>
                                <i class="custom-btn mdi mdi-close-circle" style="position:absolute; top:5px; right:5px; cursor:pointer;"></i>
                                <input asp-for="ImageIds" type="hidden"  value="@addImage.Id"/>
                            </div>
                        }
                    </div>
                    <div class="form-group">
                         <label for="Name">Additional İmages</label>
                         <input asp-for="AdditionalPhoto" class="form-control" accept="image/*">
                         <span asp-validation-for="ImageIds" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for="name">Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Name" accept="image/*">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for="name">Price</label>
                        <input asp-for="Price" class="form-control" placeholder="Price">
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for="name">SKU</label>
                        <input asp-for="SKU" class="form-control" placeholder="SKU">
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for="name">Category</label>
                        <select asp-for="CategoryId" class="form-control" asp-items="new SelectList(Model.Categories, nameof(Category.Id), nameof(Category.Name))">
                            <option selected disabled>Choose Category</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for="TagIds">Tag</label>
                        <select asp-for="TagIds" class="form-control" multiple asp-items="new SelectList(Model.Tags, nameof(Tag.Id), nameof(Tag.Name))">
                        </select>
                        <span asp-validation-for="TagIds" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label for="name">Description</label>
                        <textarea asp-for="Description" class="form-control" placeholder="Description"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary me-2">Submit</button>
                    <a asp-action="index" class="btn btn-light">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div

@section DeleteImages {
    <script>
    var btns = document.querySelectorAll(".custom-btn")
    for (let i = 0;  i <= btns.length; i++) {
        btns[i].addEventListener("click", () => {
            btns[i].parentElement.remove();
        })
    }
    </script>
}


