@model List<Category>

@{
    int count = 0; 
}
    
<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Category Table</h4>
                <div class="table-responsive">
                    <a asp-action="create" class="btn btn-outline-success btn-fw">Create</a>
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>
                                    Count
                                </th>
                                <th>
                                    Name
                                </th>
                                <th>
                                    Products
                                </th>
                                <th>
                                    Settings
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(Category category in Model)
                            {
                                count++;
                                <tr>
                                    <td>
                                        <p>@count</p>
                                    </td>
                                    <td>
                                        <p>@category.Name</p>
                                    </td>
                                    <td>
                                        <p>@category.Products.Count</p>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-outline-warning btn-fw">Edit</button>
                                        <button type="button" class="btn btn-outline-danger btn-fw">Delete</button>
                                        <button type="button" class="btn btn-outline-info btn-fw">Detail</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
