@model Category

<div class="row">
    <div class="col-md-10 grid-margin stretch-card">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="card-title mb-0">Category Details: <span class="text-primary">@Model.Name</span></h4>
                    <span class="text-muted small">ID: #@Model.Id</span>
                </div>
                <hr>

                <div class="row pt-3">
                    <div class="col-md-5">
                        <div class="info-container p-4 border rounded bg-light text-center">
                            <i class="mdi mdi-format-list-bulleted-type" style="font-size: 70px; color: #4B49AC;"></i>
                            <h5 class="mt-3">Associated Products</h5>
                            <h2 class="text-primary font-weight-bold">@(Model.Products?.Count ?? 0)</h2>
                            <p class="text-muted small">Total items in this category</p>
                        </div>
                    </div>

                    <div class="col-md-7">
                        <table class="table table-borderless">
                            <tbody>
                                <tr>
                                    <th style="width: 40%;" class="pl-0 text-muted">Category Name:</th>
                                    <td class="font-weight-bold">@Model.Name</td>
                                </tr>
                                <tr>
                                    <th class="pl-0 text-muted">Status:</th>
                                    <td style="color:black">
                                        @if (!Model.isDeleted)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">Deleted</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <th class="pl-0 text-muted">Product List:</th>
                                    <td>
                                        @if (Model.Products != null && Model.Products.Any())
                                        {
                                            <ul class="list-unstyled mb-0">
                                                @foreach (var prod in Model.Products.Take(5)) // İlk 5 məhsulu göstərək
                                                {
                                                    <li><i class="mdi mdi-check-circle-outline text-success mr-2"></i>@prod.Name</li>
                                                }
                                                @if (Model.Products.Count > 5)
                                                {
                                                    <li class="text-muted small">...and @(Model.Products.Count - 5) more</li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <span class="text-warning small italic">No products found</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-5 pt-3 border-top d-flex justify-content-end" style="gap:10px">
                    <a asp-action="Index" class="btn btn-outline-secondary" style="display:flex; align-items:center; gap:5px">
                        <i class="mdi mdi-arrow-left"></i>
                        <span>Back</span>
                    </a>
                    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-warning" style="display:flex; align-items:center; gap:5px">
                        <i class="mdi mdi-pencil"></i>
                        <span>Update</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>